ylic_acid',\n","            'niacinamide',\n","            'bha',\n","            'hyaluronic_acid',\n","            'zinc',\n","        ],\n","        '26-35': [\n","            'niacinamide',\n","            'vitamin_c',\n","            'aha',\n","            'hyaluronic_acid',\n","            'spf',\n","        ],\n","        '36-45': [\n","            'retinol',\n","            'peptides',\n","            'vitamin_c',\n","            'ceramides',\n","            'spf',\n","        ],\n","        '46-55': [\n","            'retinol',\n","            'peptides',\n","            'ceramides',\n","            'hyaluronic_acid',\n","            'coenzyme_q10',\n","            'spf',\n","        ],\n","        '56+': [\n","            'ceramides',\n","            'hyaluronic_acid',\n","            'peptides',\n","            'squalane',\n","            'coenzyme_q10',\n","            'spf',\n","        ],\n","    }\n","}\n","\n","\n","\n","\n","\n"],"metadata":{"id":"2dxchucM9juc"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def check_age_compatibility(ingredients_list, user_age):\n","    \"\"\"\n","    Rule-based age compatibility check.\n","    Returns flags and recommendations.\n","    \"\"\"\n","    flags    = []\n","    tips     = []\n","\n","    ingredients_lower = [i.strip().lower().replace(' ', '_')\n","                         for i in ingredients_list]\n","    for ingredient, rule in AGE_INGREDIENT_RULES['avoid'].items():\n","        if user_age in rule['ages']:\n","            if any(ingredient in ing for ing in ingredients_lower):\n","                flags.append({\n","                    'ingredient': ingredient,\n","                    'message': f\"{ingredient.replace('_',' ').title()} — {rule['reason']}\",\n","                    'severity': 'HIGH'\n","                })\n","\n","\n","    if user_age in AGE_INGREDIENT_RULES['recommend']:\n","        rec_ings = AGE_INGREDIENT_RULES['recommend'][user_age]\n","        found    = []\n","        missing  = []\n","\n","        for rec in rec_ings:\n","            if any(rec in ing for ing in ingredients_lower):\n","                found.append(rec)\n","            else:\n","                missing.append(rec)\n","\n","        if missing:\n","            tips.append({\n","                'message': f\"For {user_age} skin, consider products with: \"\n","                           f\"{', '.join(missing[:3]).replace('_',' ')}\",\n","                'severity': 'INFO'\n","            })\n","\n","    return flags, tips\n"],"metadata":{"id":"FKCdGjiB-KCS"},"execution_count":null,"outputs":[]}]}